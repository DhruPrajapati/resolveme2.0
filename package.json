{
  "name": "resolveme",
  "private": true,
  "workspaces": ["client", "server", "e2e"],
  "scripts": {
    "dev:client": "bun run --cwd client dev",
    "dev:server": "bun run --cwd server dev",
    "install:all": "bun install --cwd client && bun install --cwd server && bun install --cwd e2e",
    "test:e2e": "bun run --cwd e2e test",
    "test:e2e:ui": "bun run --cwd e2e test:ui"
  }
}
